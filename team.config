# ─────────────────────────────────────────────────────────────
#  TEAM CONFIG - edit this ONCE, then ship the kit to your devs.
#  Everything here is the "team layer": shared across everyone.
#  (Per-dev name/role is asked at install time - not here.)
# ─────────────────────────────────────────────────────────────

# --- who you are ---
COMPANY_NAME="Acme"                       # your company / org name
TEAM_NAME="Engineering"                    # team this kit is for
STACK="TypeScript · Next.js · PostgreSQL · pnpm"   # your primary stack (free text)
REPO_HINT="github.com/acme"               # where your repos live (shown to devs)

# --- engineering standards (the short version; full version in templates/CLAUDE.md.template) ---
# These three lines get injected verbatim into every dev's CLAUDE.md.
# Keep them punchy - they're rules the agent will actually follow.
STANDARD_1="Conventional commits. Small PRs. Tests with every behavior change."
STANDARD_2="No secrets in code or commits, ever. Named exports. Typed everything."
STANDARD_3="Match the surrounding code. Ask the spec, not the human, when blocked."

# --- which MCP tools to wire up (1 = on, 0 = off) ---
MCP_CONTEXT7=1        # live, version-accurate library/framework docs   (recommended ON)
MCP_PLAYWRIGHT=1      # headless browser for QA / e2e / screenshots      (recommended ON)
MCP_GITMCP=1          # git & repo documentation lookups                (recommended ON)
MCP_FIGMA=0           # design-to-code; turn ON for frontend teams
MCP_NOTION=0          # if your team lives in Notion
MCP_AUTOMATOR=0       # macOS automation (niche)

# --- which official plugins to install (1 = on, 0 = off) ---
PLUGIN_SUPERPOWERS=1     # brainstorming, planning, TDD, debugging engine (recommended ON)
PLUGIN_FRONTEND=1        # distinctive, non-generic frontend design        (ON for product teams)
PLUGIN_GITHUB=1          # PRs, issues, repo ops from inside Claude         (recommended ON)

# --- per-dev local brain (memory across sessions) ---
ENABLE_BRAIN=1           # 1 = each dev gets a private local brain; 0 = skip

# --- model + theme defaults for every dev ---
DEFAULT_MODEL="claude-opus-4-8"
DEFAULT_THEME="dark"
